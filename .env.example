# Copy to .env and fill in your values

# Your real Anthropic API key (passed through to Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Proxy bind address (default: 127.0.0.1 — local only)
ANONYMYZR_HOST=127.0.0.1

# Proxy port (default: 8080)
ANONYMYZR_PORT=8080

# Override Claude API endpoint (optional, e.g. for custom gateways)
# ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
